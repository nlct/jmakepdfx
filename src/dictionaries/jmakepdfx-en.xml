<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>
<comment>English language file for jmakepdfx
https://github.com/nlct/jmakepdfx
GPL-3.0
Nicola Talbot
</comment>

<!--  Syntax -->
<entry key="syntax.title">Syntax:</entry>
<entry key="syntax.options">{0} [&lt;option&gt;]+ [&lt;in PDF&gt;] [&lt;out PDF&gt;]</entry>
<entry key="syntax.in">{0} (or {1})	Input PDF file (required for batch mode).</entry>
<entry key="syntax.out">{0} (or {1})	Output PDF file (required for batch mode).</entry>
<entry key="syntax.gui">{0} (or {1})	Run in GUI mode (default).</entry>
<entry key="syntax.batch">{0} (or {1})	Run in batch mode.</entry>


<!-- Menus -->
<entry key="menu.file">File</entry>
<entry key="menu.file.mnemonic">F</entry>

<entry key="menu.file.input">Input PDF...</entry>
<entry key="menu.file.input.mnemonic">I</entry>
<entry key="menu.file.input.iconimage">inbox</entry>
<entry key="menu.file.input.keystroke">ctrl O</entry>
<entry key="menu.file.input.tooltip">Select input PDF file</entry>

<entry key="menu.file.output">Output PDF...</entry>
<entry key="menu.file.output.mnemonic">D</entry>
<entry key="menu.file.output.iconimage">outbox</entry>
<entry key="menu.file.output.keystroke">ctrl S</entry>
<entry key="menu.file.output.tooltip">Select output PDF file</entry>

<entry key="menu.file.quit">Quit</entry>
<entry key="menu.file.quit.mnemonic">Q</entry>
<entry key="menu.file.quit.keystroke">ctrl Q</entry>
<entry key="menu.file.quit.tooltip">Exit application</entry>
<entry key="menu.file.quit.description">This menu item quits the application</entry>

<entry key="menu.help.manual.iconimage">manual</entry>

<entry key="menu.help.about">About</entry>
<entry key="menu.help.about.mnemonic">A</entry>

<entry key="menu.help.license">License</entry>
<entry key="menu.help.license.mnemonic">L</entry>

<!-- Main Component -->

<entry key="inputfile.label">Input File:</entry>
<entry key="inputfile.label.mnemonic">I</entry>

<entry key="inputfile.choosein">Choose...</entry>
<entry key="inputfile.choosein.iconimage">open</entry>

<entry key="outputfile.label">Output File:</entry>
<entry key="outputfile.label.mnemonic">O</entry>

<entry key="outputfile.chooseout">Choose...</entry>
<entry key="outputfile.chooseout.iconimage">open</entry>

<entry key="pdfinfo.title">PDF Info</entry>

<entry key="pdfinfo.pdftitle">Title:</entry>
<entry key="pdfinfo.pdftitle.mnemonic">E</entry>

<entry key="pdfinfo.pdfauthor">Author:</entry>
<entry key="pdfinfo.pdfauthor.mnemonic">A</entry>

<entry key="pdfinfo.pagecount">Page Count:</entry>
<entry key="pdfinfo.filesize">File Size:</entry>

<!-- File Filter -->

<entry key="filter.pdf">PDF Document</entry>

<!-- About Dialog -->

<entry key="about.title">About {0}</entry>
<entry key="about.defaultparams">\meta'{'name'}'</entry>

<!-- License Dialog -->

<entry key="license.title">License</entry>

<!-- Error Messages -->
<entry key="error.batch_requires_in">Batch mode requires input file</entry>
<entry key="error.batch_requires_out">Batch mode requires output file</entry>

<entry key="error.syntax.only_one_inout">Only one input file and output file permitted</entry>

</properties>
